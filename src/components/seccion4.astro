      href={whatsappLink}
      target="_blank"
      rel="noopener noreferrer"
      class="flex items-center gap-3 bg-amber-400 hover:bg-amber-300 active:scale-95 text-black font-bold text-base sm:text-lg px-6 sm:px-8 py-3 rounded-lg shadow-xl transition-all duration-200 whitespace-nowrap flex-shrink-0"

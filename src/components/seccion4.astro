---


const combos = [
  {
    nombre: "Mediana + Postobón 1.5",
    precio: "$42.000",
  },
  {
    nombre: "Familiar + Postobón 1.5",
    precio: "$54.000",
  },
];

const nuevosSabores = [
  {
    nombre: "Brasilera",
    ingredientes: "Chorizo + Topping de Cerdo + Tomate + Pepperoni + Limón al Gusto",
  },
  {
    nombre: "Suprema",
    ingredientes: "Pepperoni + Pimentón + Cebolla + Champiñón + Topping de Cerdo",
  },
  {
    nombre: "Pollo Ranch",
    ingredientes: "Tocineta Salsa Ranch + Pollo + Cebolla + Tomate + Tocineta",
  },
];


const whatsappLink = "https://wa.me/573227744136?text=Hola!%20Quiero%20pedir%20una%20pizza";
---


<section class="relative flex items-stretch bg-[#1a1a1a] min-h-[420px] overflow-hidden">

 
  <div class="hidden md:flex flex-shrink-0 w-40 lg:w-52 xl:w-64 overflow-hidden" aria-hidden="true">
     <img src="../../public/postobon_1.5.png" alt="" class="w-full h-full object-cover object-center bg-gradient-to-r from-[#2d0e00] to-[#1a1a1a] " />
   
  </div>

  <!-- ── Contenido central ── -->
  <div class="flex-1 flex flex-col md:flex-row gap-8 md:gap-0 px-4 sm:px-6 md:px-8 py-8 relative z-0">

   
    <div class="flex-1 flex flex-col bg-gradient-to-r from-red-900/10 to-red-700/10 rounded-lg px-6 py-8 shadow-lg shadow-red-500/50">

      <div class="bg-gradient-to-r from-red-900 via-red-700 to-red-900 rounded-xl px-6 py-3 mb-6 text-center shadow-lg shadow-red-950/60">
        <h2 class="font-sans text-white text-xl sm:text-2xl font-bold tracking-wide drop-shadow">
          Combos Pizzeros
        </h2>
      </div>

      <!-- Lista de combos -->
      <ul class="flex flex-col gap-5">
        {combos.map((combo) => (
          <li class="flex flex-col gap-1 bg-gradient-to-r from-red-900/10 to-red-700/10 rounded-lg px-4 py-3 border-b border-white/5 last:border-0 transition-transform duration-200 hover:translate-x-1 cursor-default">
            <span class="font-sans text-white text-base sm:text-lg font-medium leading-snug">
              {combo.nombre}
            </span>
            <span class="font-sans text-amber-400 text-2xl sm:text-3xl font-bold tracking-wide">
              {combo.precio}
            </span>
          </li>
        ))}
      </ul>
    </div>

    <!-- Divisor vertical (desktop) -->
    <div class="hidden md:block w-px mx-6" aria-hidden="true"></div>

    <!-- Divisor horizontal (móvil) -->
    <div class="md:hidden h-px bg-gradient-to-r from-transparent via-red-800/40 to-transparent" aria-hidden="true"></div>

    <!-- Columna derecha: Nuevos Sabores -->
    <div class="flex-1 flex flex-col bg-gradient-to-r from-red-900/10 to-red-700/10 rounded-lg px-6 py-8 shadow-lg shadow-red-500/50">

      <!-- Header rojo -->
      <div class="bg-gradient-to-r from-red-900 via-red-700 to-red-900 rounded-xl px-6 py-3 mb-6 text-center shadow-lg shadow-red-950/60">
        <h2 class="font-sans text-white text-xl sm:text-2xl font-bold tracking-wide drop-shadow">
          Nuevos Sabores! 🔥
        </h2>
      </div>

      <!-- Lista de sabores -->
      <ul class="flex flex-col gap-4">
        {nuevosSabores.map((item) => (
          <li class="flex flex-col gap-1 bg-gradient-to-r from-red-900/10 to-red-700/10 rounded-lg px-4 py-2 border-b border-white/5 last:border-0 transition-transform duration-200 hover:translate-x-1 cursor-default">
            <span class="font-sans text-amber-400 text-lg sm:text-xl font-extrabold leading-snug">
              {item.nombre}🔥
            </span>
            <span class="text-sm font-bold text-white  tracking-wide leading-relaxed">
              {item.ingredientes}
            </span>
          </li>
        ))}
      </ul>
    </div>

  </div>

 
  <div class="hidden md:flex flex-shrink-0 w-40 lg:w-52 xl:w-96 relative z-0" aria-hidden="true">
    <img src="/pizzaDEC.png" alt="" class="w-full h-full object-cover object-center bg-gradient-to-l from-[#2d0e00] to-[#1a1a1a] " />
    

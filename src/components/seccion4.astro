      <div class="flex flex-col">
        <span class="text-white font-bold text-xl sm:text-2xl md:text-3xl leading-tight">
          Pide tu pizza favorita
        </span>
        <span class="text-amber-400 font-bold text-lg sm:text-xl md:text-2xl leading-tight">
          ¡Y disfrútala en casa!
        </span>
      </div>
    </div>


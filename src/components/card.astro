---
interface Props {
   title: string;
   description: string;
   imageUrl: string;
}
const { title, description, imageUrl } = Astro.props as Props;
---
<div class="bg-white/90 backdrop-blur-sm rounded-lg shadow-lg p-6 text-center hover:shadow-xl transition-shadow duration-300">
   <div class="mb-4">
       <img src={imageUrl} alt={title} class="w-24 h-24 mx-auto object-contain "/>
   </div>
   <div class="flex-col">
       <h2 class="text-xl font-bold text-gray-800 mb-2">{title}</h2>
       <p class="text-red-600 font-semibold text-lg">{description}</p>
   </div>
</div>
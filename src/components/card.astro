---
interface Props {
   title: string;
   description: string;
   imageUrl: string;
   porciones?: string;
}
const { title, description, imageUrl, porciones } = Astro.props as Props;

---
<div class="bg-transparent  border-r-3 border-b-gray-950 border-dashed rounded-lg shadow-lg p-6 text-center hover:shadow-xl transition-shadow duration-300">
   <div class="mb-4 flex items-center justify-center">
       <img src={imageUrl} alt={title} class="w-8/12 m-auto object-contain  {}"/>
   </div>
   <div class="flex-col text-center font-sans">
       <h2 class="text-3xl font-bold text-amber-400 mb-2">{title}</h2>
         <p class="text-2xl text-white  font-sans mb-1">{porciones}</p>
       <p class=" text-3xl text-yellow-400 font-bold ">{description}</p>
   </div>
</div>
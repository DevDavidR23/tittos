---

import { getCollection } from "astro:content";
import Card from "../components/card.astro";
const pizzas = await getCollection("pizzas");
pizzas.reverse();
---

<section
    class="bg-[url('/fondo2.png')] w-full min-h-screen lg:min-h-0  md:bg-cover  p-4 sm:p-6 md:p-10"
>
    <div class="mx-auto max-w-7xl">
        <div class="flex flex-col items-center justify-center gap-4 text-center">

            <!-- SVG decorativo: líneas y pizza -->
            <div class="flex items-center justify-center gap-2 w-full">
                <span class="flex-1 max-w-[60px] sm:max-w-[100px] h-[2px] bg-red-500 rounded"></span>
                <svg
                    fill="red"
                    class="w-10 h-10 sm:w-14 sm:h-14 flex-shrink-0"
                    viewBox="-3 0 19 19"
                    xmlns="http://www.w3.org/2000/svg"
                >
                    <path
                        d="M11.816 3.746a.55.55 0 0 1-.193-.035 14.657 14.657 0 0 0-10.246-.005.554.554 0 0 1-.386-1.04 15.767 15.767 0 0 1 11.018.006.554.554 0 0 1-.193 1.074zm-.446.922s-.311-.12-.697-.243a13.82 13.82 0 0 0-8.202-.05c-.43.132-.84.29-.84.29a.463.463 0 0 0-.262.61l4.943 11.95c.1.241.263.241.363 0L11.631 5.28a.464.464 0 0 0-.26-.61zM2.85 6.372a1.425 1.425 0 1 1 1.425 1.425A1.425 1.425 0 0 1 2.85 6.372zm3.662 6.971a1.425 1.425 0 1 1 1.425-1.425 1.425 1.425 0 0 1-1.425 1.425zM8.17 9.388a1.425 1.425 0 1 1 1.425-1.425A1.425 1.425 0 0 1 8.17 9.388z"
                    ></path>
                </svg>
                <span class="flex-1 max-w-[60px] sm:max-w-[100px] h-[2px] bg-amber-600 rounded"></span>
            </div>

            <!-- Título "Nuestros Tamaños De Pizza" -->
            <div class="flex items-center justify-center gap-2 w-full px-2">
                <span class="flex-1 max-w-[40px] sm:max-w-[80px] h-[2px] bg-red-700 rounded"></span>
                <h1 class="text-white  font-mono text-2xl sm:text-2xl md:text-5xl font-extrabold leading-tight whitespace-nowrap">
                    Nuestros Tamaños De Pizza
                </h1>
                <span class="flex-1 max-w-[40px] sm:max-w-[80px] h-[2px] bg-amber-600 rounded"></span>
            </div>

        </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mt-10 md:mt-14">
        {
            pizzas.map((pizza: any) => (
                <Card
                    title={pizza.data.title}
                    description={pizza.data.description}
                    imageUrl={pizza.data.img}
                    porciones={pizza.data.porciones}
                />
            ))
        }
    </div>
</section>